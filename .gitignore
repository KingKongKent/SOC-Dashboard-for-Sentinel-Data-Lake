# ===========================================================
# SOC Dashboard .gitignore — SECURITY-FIRST
# ===========================================================

# ---- Python ----
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
dist/
*.egg-info/
__pycache__/
*.pyo

# ---- Secrets / Credentials — NEVER COMMIT ----
.env
.env.*
!.env.example
config.py
secrets.json
*.pem
*.key
*.pfx
*.p12
*credentials*
*secret*
!SECURITY.md

# ---- Database files — Created at runtime ----
*.db
*.db-journal
soc_dashboard.db
soc_dashboard.db.backup

# ---- Generated data — Created at runtime ----
dashboard_data.json
dashboard_data.json.backup
*.backup

# ---- Migration artifacts ----
migrate_json_to_db.py
rollback_to_json.py
DATABASE_MIGRATION_README.md
MIGRATION_SUCCESS.md

# ---- Logs ----
*.log
logs/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Node (if frontend ever added) ----
node_modules/
.next/
.nuxt/

# ---- Flask session files ----
flask_sessions/

# ---- Local-only Copilot / deployment files (contain IPs, domains) ----
.github/copilot-instructions.local.md
skills/soc-dashboard-deployment/

# ---- Test / scratch scripts ----
parse_api.py
test_graph.py
