# =============================================================
# SOC Dashboard Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it is gitignored
# =============================================================

# --- Microsoft Entra ID (App Registration) ---
CLIENT_ID=your-app-client-id
CLIENT_SECRET=your-client-secret
TENANT_ID=your-tenant-id

# --- Microsoft Sentinel Workspace ---
SENTINEL_WORKSPACE_ID=your-workspace-id
SENTINEL_WORKSPACE_NAME=your-workspace-name

# --- Azure Resource IDs (for IOC Upload to Sentinel) ---
AZURE_SUBSCRIPTION_ID=your-subscription-guid
AZURE_RESOURCE_GROUP=your-resource-group-name

# --- Optional: Threat Intel API Keys ---
VIRUSTOTAL_API_KEY=
TALOS_API_KEY=
ABUSEIPDB_API_KEY=

# --- Flask Settings (local development only — production uses gunicorn via systemd) ---
# Set to 0 in production (disables debugger/reloader)
FLASK_DEBUG=0
# Bind address: use 127.0.0.1 to restrict to local only
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# --- Session & Auth ---
# Random string used to sign session cookies — GENERATE A UNIQUE VALUE:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string
# Redirect URI for OAuth (must match Entra app registration)
REDIRECT_URI=https://your-domain.com/auth/callback
# Allowed CORS origins
CORS_ORIGINS=https://your-domain.com
# Comma-separated admin email addresses
ADMIN_USERS=admin@yourdomain.com

# --- Escalation ---
# Comma-separated enabled methods: email, teams_graph, teams_webhook
ESCALATION_METHODS=email
# Email address for escalation notifications (requires Mail.Send permission)
ESCALATION_EMAIL=soc-team@yourdomain.com
# Microsoft Teams channel for escalation notifications (optional)
# Format: teamId/channelId — requires ChannelMessage.Send delegated permission
TEAMS_CHANNEL_ID=
# Microsoft Teams webhook URL (optional, simpler — no Graph permissions needed)
# Supports: Power Automate Workflows, classic Incoming Webhooks
TEAMS_WEBHOOK_URL=

# --- AI & Data Lake (Azure AI Foundry) ---
# Azure OpenAI / AI Foundry endpoint URL
FOUNDRY_ENDPOINT=
# Model deployment name (e.g. gpt-4o)
FOUNDRY_DEPLOYMENT=
# AI Foundry project endpoint (enables MCP agent mode with Sentinel tools)
FOUNDRY_PROJECT_ENDPOINT=
# Optional named agent in Foundry project
FOUNDRY_AGENT_NAME=

# --- Feature Toggles ---
# Set to true to enable, false to disable (all default false)
AI_ASSISTANT_ENABLED=false
KQL_CONSOLE_ENABLED=false
MDTI_ENABLED=true
AI_AUTO_ENRICH_ENABLED=false
AI_AUTO_COMMENT_ENABLED=false
CLOSE_INCIDENT_ENABLED=false
LOGS_ENABLED=false

# Number of incidents to display in the table (10-1000)
INCIDENTS_DISPLAY_LIMIT=100

# --- Storage Paths (production) ---
# Where to store the Fernet encryption key for DB secrets
CONFIG_KEY_PATH=/var/lib/soc-dashboard/.encryption_key
# Database path
DB_PATH=/var/lib/soc-dashboard/soc_dashboard.db
